# Project Mohenjo - Optimized .gitignore

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Bun specific
bun.lockb
.bun-build/

# Next.js build output
/.next/
/out/
/build

# Convex specific (Crucial: prevents leaking cloud URLs/keys)
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
/convex/_generated

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-debug.log*

# OS metadata
.DS_Store
Thumbs.db
*.pem

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

